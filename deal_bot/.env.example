# .env.example — Camelot OS Deal Bot
# =====================================
# Copy to .env and fill in real values. NEVER commit .env to version control.

# ── HubSpot ───────────────────────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── Prospeo (email finder) ────────────────────────────────────────────────────
# Default value is set in code — override here to use a different key
PROSPEO_API_KEY=pk_6f97626856799b713a4ffb240921cf40e447e3109380105462ced244f53cd771

# ── Google Places API ─────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# ── NYC Open Data ─────────────────────────────────────────────────────────────
NYC_OPEN_DATA_APP_TOKEN=your_socrata_app_token

# ── SMTP (for email sequence delivery) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dgoldoff@camelot.nyc
SMTP_PASSWORD=your_smtp_app_password
SMTP_FROM=dgoldoff@camelot.nyc
SMTP_FROM_NAME=David Goldoff — Camelot

# ── Outreach sender identity ──────────────────────────────────────────────────
DEAL_BOT_SENDER_NAME=David Goldoff
DEAL_BOT_SENDER_TITLE=Managing Partner, Camelot Property Management
DEAL_BOT_SENDER_EMAIL=dgoldoff@camelot.nyc
DEAL_BOT_SENDER_PHONE=(212) 555-0100
CAMELOT_WEBSITE=https://camelot.nyc

# ── Output ────────────────────────────────────────────────────────────────────
DEAL_BOT_OUTPUT_DIR=output/deal_bot

# ── Server ────────────────────────────────────────────────────────────────────
DEAL_BOT_PORT=8004
DEAL_BOT_HOST=0.0.0.0

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/deal_bot.log
