# .env.example — Camelot OS Report Bot
# ======================================
# Copy to .env and fill in real values. NEVER commit .env to version control.

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── HubSpot ───────────────────────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── SMTP (for report email delivery) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=reports@camelot.nyc
SMTP_PASSWORD=your_smtp_app_password
SMTP_FROM=reports@camelot.nyc

# ── NYC Open Data (Socrata) ───────────────────────────────────────────────────
NYC_OPEN_DATA_APP_TOKEN=your_socrata_app_token

# ── Report output ─────────────────────────────────────────────────────────────
REPORT_OUTPUT_DIR=output/reports

# ── Scheduler ─────────────────────────────────────────────────────────────────
MONTHLY_STATEMENTS_TIME=06:00
WEEKLY_KPI_TIME=08:00
QUARTERLY_UPDATE_TIME=07:00
SCHEDULER_PID_FILE=/tmp/camelot_report_scheduler.pid

# ── Email alert recipients ────────────────────────────────────────────────────
REPORT_ALERT_EMAIL=dgoldoff@camelot.nyc
REPORT_EMAIL_DELIVERY=true

# ── Portfolio BBLs (NYC Borough-Block-Lot, comma-separated) ──────────────────
# Used by violation collectors to filter HPD/DOB data for portfolio buildings
PORTFOLIO_BBLS=1-01234-0001,2-05678-0002

# ── Server ────────────────────────────────────────────────────────────────────
REPORT_BOT_PORT=8003
REPORT_BOT_HOST=0.0.0.0

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/report_bot.log
