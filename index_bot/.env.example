# index_bot/.env.example
# Copy to .env and fill in your values. Never commit .env to source control.

# Google Service Account (for Drive + Sheets access)
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json

# Google Drive
CAMELOT_DRIVE_ROOT=Camelot

# Google Sheets Index
SHEETS_INDEX_SPREADSHEET_ID=your_google_sheets_spreadsheet_id_here
SHEETS_INDEX_NAME=Camelot Drive Index

# Make.com webhook secret (set same value in Make.com scenario)
MAKE_WEBHOOK_SECRET=your_random_webhook_secret_here

# API server
API_HOST=0.0.0.0
API_PORT=8002

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/index_bot.log
ENVIRONMENT=production
