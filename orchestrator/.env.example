# =============================================================================
# Camelot OS — Master Environment Variables
# .env.example
#
# Copy this file to .env and fill in all values before running.
# NEVER commit your real .env file to version control.
#
# Sections:
#   1. Core Orchestrator
#   2. Supabase (Database & Memory)
#   3. OpenAI
#   4. HubSpot CRM
#   5. Google APIs
#   6. Email / SMS (SendGrid + Twilio)
#   7. Property Management Software (AppFolio, Buildium)
#   8. NYC Open Data
#   9. CoStar
#   10. Scout Bot
#   11. Compliance Bot
#   12. Concierge Bot
#   13. Index Bot
#   14. Report Bot
#   15. Deal Bot
#   16. Infrastructure / Docker
# =============================================================================


# -----------------------------------------------------------------------------
# 1. CORE ORCHESTRATOR
# -----------------------------------------------------------------------------
ENV=production                                        # development | staging | production
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
LOG_FILE=logs/camelot_os.log
SECRET_KEY=replace-with-a-long-random-secret-key      # Used for JWT / webhook signatures


# -----------------------------------------------------------------------------
# 2. SUPABASE (Database, Persistent Memory, All Bot Data Storage)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # Service role key (full access)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...      # Anon key (client-safe)


# -----------------------------------------------------------------------------
# 3. OPENAI (Used by Broker, Deal, Index, Report bots for LLM tasks)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...                                 # Optional: your OpenAI organization ID
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4o-mini


# -----------------------------------------------------------------------------
# 4. HUBSPOT CRM (Scout + Deal bots for lead and deal management)
# -----------------------------------------------------------------------------
HUBSPOT_API_KEY=pat-na1-...
HUBSPOT_PORTAL_ID=12345678
HUBSPOT_ACQUISITION_PIPELINE_ID=default
HUBSPOT_PROPERTY_PIPELINE_ID=property-mgmt
HUBSPOT_OWNER_ID=                                     # Default deal owner user ID


# -----------------------------------------------------------------------------
# 5. GOOGLE APIs (Index bot for Drive, Deal bot for Search, Scout for Maps)
# -----------------------------------------------------------------------------
# Service account JSON — paste the entire JSON as a single line, or set path
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=secrets/google-service-account.json

GOOGLE_DRIVE_ROOT_FOLDER_ID=1AbCdEfGhIjKlMnOpQrSt   # Root Camelot Drive folder ID
GOOGLE_MAPS_API_KEY=AIza...
GOOGLE_SEARCH_API_KEY=AIza...
GOOGLE_SEARCH_CX=abc123:xyz789                        # Custom Search Engine ID


# -----------------------------------------------------------------------------
# 6. EMAIL / SMS NOTIFICATIONS
# -----------------------------------------------------------------------------

# SendGrid (transactional email — Report bot outreach, Concierge notifications)
SENDGRID_API_KEY=SG.abc...
SENDGRID_FROM_EMAIL=ops@camelotpms.com
SENDGRID_FROM_NAME=Camelot OS
SENDGRID_TEMPLATE_WEEKLY_KPI=d-abc123...
SENDGRID_TEMPLATE_MAINTENANCE=d-def456...
SENDGRID_TEMPLATE_VIOLATION=d-ghi789...
SENDGRID_TEMPLATE_OUTREACH=d-jkl012...

# Report recipients (comma-separated or set individually)
REPORT_RECIPIENT_1=leadership@camelotpms.com
REPORT_RECIPIENT_2=investors@camelotpms.com

# Twilio (SMS/voice — Concierge bot for emergency escalation and tenant SMS)
TWILIO_ACCOUNT_SID=ACabc123...
TWILIO_AUTH_TOKEN=abc123...
TWILIO_FROM_NUMBER=+12125550100                       # Camelot's Twilio number
TWILIO_EMERGENCY_NUMBER=+12125550911                  # On-call emergency line


# -----------------------------------------------------------------------------
# 7. PROPERTY MANAGEMENT SOFTWARE
# -----------------------------------------------------------------------------

# AppFolio (primary PM platform for Concierge, Report bots)
APPFOLIO_API_KEY=...
APPFOLIO_CLIENT_ID=...
APPFOLIO_BASE_URL=https://api.appfolio.com/api/v2
APPFOLIO_PM_ID=                                       # Default property manager ID

# Buildium (secondary PM platform)
BUILDIUM_API_KEY=...
BUILDIUM_BASE_URL=https://api.buildium.com/v1


# -----------------------------------------------------------------------------
# 8. NYC OPEN DATA (Compliance bot — HPD, DOB, ECB, PLUTO, ACRIS)
# -----------------------------------------------------------------------------
NYC_OPEN_DATA_APP_TOKEN=...                           # Register at data.cityofnewyork.us


# -----------------------------------------------------------------------------
# 9. COSTAR (Scout bot — market data, comps, property intel)
# -----------------------------------------------------------------------------
COSTAR_API_KEY=...
COSTAR_BASE_URL=https://api.costar.com/v1


# -----------------------------------------------------------------------------
# 10. SCOUT BOT SPECIFIC
# -----------------------------------------------------------------------------
PROPERTYRADAR_API_KEY=...                             # PropertyRadar for ownership data
REONOMY_API_KEY=...                                   # Reonomy for property intelligence
STREETVIEW_API_KEY=...                                # Google Street View for property photos

# Default search parameters
SCOUT_DEFAULT_MIN_UNITS=25
SCOUT_DEFAULT_REGIONS=NYC,Westchester,NJ,CT,FL
SCOUT_MAX_RESULTS=50


# -----------------------------------------------------------------------------
# 11. COMPLIANCE BOT SPECIFIC
# -----------------------------------------------------------------------------
# NYC Open Data token (shared with section 8 above)
# No additional credentials — all data from public APIs

# LL97 fine rates (update annually)
LL97_FINE_PER_TON_CO2E=268.00                         # $/ton CO2e per year (2024)

# Notification settings for violation alerts
COMPLIANCE_ALERT_EMAIL=compliance@camelotpms.com
COMPLIANCE_ALERT_PHONE=+12125550100


# -----------------------------------------------------------------------------
# 12. CONCIERGE BOT SPECIFIC
# -----------------------------------------------------------------------------
CONCIERGE_API_PORT=8001
CONCIERGE_EMERGENCY_ESCALATION_EMAIL=emergency@camelotpms.com
CONCIERGE_MAINTENANCE_LEAD_EMAIL=maintenance@camelotpms.com

# Vendor database (if using external vendor management)
VENDOR_DB_URL=                                        # Optional: external vendor API


# -----------------------------------------------------------------------------
# 13. INDEX BOT SPECIFIC
# -----------------------------------------------------------------------------
INDEX_BOT_API_PORT=8002
INDEX_BOT_BATCH_SIZE=20                               # Files to process per batch
INDEX_BOT_SCHEDULE=0 2 * * *                          # Cron: daily at 2 AM UTC

# Document expiration alerting
INDEX_EXPIRY_ALERT_DAYS=30                            # Alert N days before document expiry
INDEX_EXPIRY_ALERT_EMAIL=legal@camelotpms.com


# -----------------------------------------------------------------------------
# 14. REPORT BOT SPECIFIC
# -----------------------------------------------------------------------------
REPORT_WEEKLY_SCHEDULE=0 8 * * 1                      # Cron: Monday 8 AM UTC
REPORT_MONTHLY_SCHEDULE=0 9 1 * *                     # Cron: 1st of month 9 AM UTC
REPORT_TIMEZONE=America/New_York


# -----------------------------------------------------------------------------
# 15. DEAL BOT SPECIFIC
# -----------------------------------------------------------------------------
DEAL_BOT_OUTREACH_FROM=acquisitions@camelotpms.com
DEAL_BOT_OUTREACH_FROM_NAME=Camelot Property Management Services

# LinkedIn Sales Navigator (optional — for company research)
LINKEDIN_CLIENT_ID=...
LINKEDIN_CLIENT_SECRET=...

# ZoomInfo (optional — for contact data enrichment)
ZOOMINFO_API_KEY=...


# -----------------------------------------------------------------------------
# 16. INFRASTRUCTURE / DOCKER
# -----------------------------------------------------------------------------

# Service hostnames (used in docker-compose networking)
ORCHESTRATOR_HOST=orchestrator
CONCIERGE_BOT_HOST=concierge_bot
INDEX_BOT_HOST=index_bot
COMPLIANCE_BOT_HOST=compliance_bot

# Internal service ports
ORCHESTRATOR_PORT=8000
CONCIERGE_BOT_PORT=8001
INDEX_BOT_PORT=8002
COMPLIANCE_BOT_PORT=8003

# Logging
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Health check settings
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3
