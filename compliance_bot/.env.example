# compliance_bot/.env.example
# Copy to .env and fill in your values. Never commit .env to source control.

# NYC Open Data App Token (increases API rate limits; optional but recommended)
NYC_OPEN_DATA_APP_TOKEN=your_nyc_open_data_app_token_here

# SMTP Configuration (for alert emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=compliance@camelot.nyc
SMTP_PASSWORD=your_smtp_app_password_here
SMTP_FROM=Camelot Compliance Bot <compliance@camelot.nyc>

# Supabase (for compliance audit log)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Portfolio JSON file path
PORTFOLIO_JSON=portfolio.json

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/compliance_bot.log
