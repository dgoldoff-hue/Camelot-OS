# =============================================================================
# Scout Bot — Environment Variables
# Camelot Property Management Services Corp.
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================


# =============================================================================
# ENRICHMENT — Apollo.io
# =============================================================================

# Apollo.io API key (Private App, read:people + read:organizations scopes)
# Get yours at: https://developer.apollo.io/
APOLLO_API_KEY=your_apollo_api_key_here


# =============================================================================
# ENRICHMENT — Prospeo
# =============================================================================

# Prospeo API key
# Get yours at: https://prospeo.io/api
# Default (provided for Scout Bot): pk_6f97626856799b713a4ffb240921cf40e447e3109380105462ced244f53cd771
PROSPEO_API_KEY=pk_6f97626856799b713a4ffb240921cf40e447e3109380105462ced244f53cd771


# =============================================================================
# CRM — HubSpot
# =============================================================================

# HubSpot Private App access token
# Create at: HubSpot Portal → Settings → Integrations → Private Apps
# Required scopes: crm.objects.contacts.write, crm.objects.companies.write,
#                  crm.objects.deals.write, crm.schemas.deals.read
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token_here


# =============================================================================
# EMAIL — SMTP
# =============================================================================

# SMTP server hostname
# Examples: smtp.gmail.com | smtp.sendgrid.net | smtp.mailgun.org | mail.camelot.nyc
SMTP_HOST=smtp.gmail.com

# SMTP port
# 587 = STARTTLS (recommended) | 465 = SSL/TLS | 25 = plain (not recommended)
SMTP_PORT=587

# SMTP authentication username (usually your email address or API username)
SMTP_USER=leads-bot@camelot.nyc

# SMTP authentication password (or API key / app password)
SMTP_PASSWORD=your_smtp_password_here

# Sender "From" address
SMTP_FROM=leads-bot@camelot.nyc

# Use STARTTLS? true (recommended for port 587) | false
SMTP_USE_TLS=true

# Use direct SSL? true for port 465 | false for port 587
SMTP_USE_SSL=false


# =============================================================================
# NYC OPEN DATA — Socrata
# =============================================================================

# Optional: Socrata App Token for higher API rate limits on NYC Open Data
# Register at: https://data.cityofnewyork.us/profile/app_tokens
# Without a token, anonymous requests are rate-limited to ~1 req/sec
SOCRATA_APP_TOKEN=


# =============================================================================
# SUPABASE (Optional — persistent lead storage)
# =============================================================================

# Supabase project URL
# Find at: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (server-side only — never expose to client)
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Supabase anon/public key (safe for read-only public queries)
SUPABASE_ANON_KEY=your_supabase_anon_key_here


# =============================================================================
# OPTIONAL — Override config.yaml values at runtime
# =============================================================================

# Minimum lead score to keep (overrides config.yaml min_lead_score)
# SCOUT_MIN_SCORE=40

# Maximum leads to enrich per run (overrides config.yaml max_enrichments_per_run)
# SCOUT_MAX_ENRICHMENTS=20

# Comma-separated extra report recipients
# SCOUT_EXTRA_RECIPIENTS=extra@example.com,another@example.com
