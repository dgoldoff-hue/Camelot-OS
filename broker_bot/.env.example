# .env.example — Camelot OS Broker Bot
# ========================================
# Copy to .env and fill in real values. NEVER commit .env to version control.

# ── HubSpot ───────────────────────────────────────────────────────────────────
# HubSpot Private App token — used by hubspot_deals.js
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── NYC Open Data (Socrata) ───────────────────────────────────────────────────
# Used by comp_analyzer.py for ACRIS sales data
NYC_OPEN_DATA_APP_TOKEN=your_socrata_app_token

# ── Google Places API ─────────────────────────────────────────────────────────
# Used by listing_analyzer.py and comp_analyzer.py for address enrichment
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# ── Supabase ──────────────────────────────────────────────────────────────────
# Used for persisting comp data and deal records
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── SMTP (for LOI and deal memo delivery) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=eleni@camelot.nyc
SMTP_PASSWORD=your_smtp_app_password
SMTP_FROM=eleni@camelot.nyc
SMTP_FROM_NAME=Eleni Palmeri — Camelot Realty Group

# ── Broker identity ───────────────────────────────────────────────────────────
BROKER_NAME=Eleni Palmeri
BROKER_TITLE=Broker of Record
BROKER_EMAIL=eleni@camelot.nyc
BROKER_PHONE=(212) 555-0200
BROKER_LICENSE=NY-XXXXXXXXX
FIRM_NAME=Camelot Realty Group
FIRM_ADDRESS=New York, NY

# ── Output ────────────────────────────────────────────────────────────────────
BROKER_BOT_OUTPUT_DIR=output/broker_bot

# ── Server ────────────────────────────────────────────────────────────────────
BROKER_BOT_PORT=8005
BROKER_BOT_HOST=0.0.0.0

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/broker_bot.log

# ── Report formatting ─────────────────────────────────────────────────────────
# Logo path for PDF headers (optional)
BROKER_LOGO_PATH=assets/camelot_logo.png
