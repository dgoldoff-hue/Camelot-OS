# concierge_bot/.env.example
# Copy to .env and fill in your values. Never commit .env to source control.

# Email (IMAP + SMTP)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=concierge@camelot.nyc
IMAP_PASSWORD=your_gmail_app_password_here
IMAP_MAILBOX=INBOX

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=concierge@camelot.nyc
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_FROM=Camelot Concierge <concierge@camelot.nyc>

# Twilio SMS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+12125550100

# On-call phone (receives emergency alerts)
ONCALL_PHONE=+12125550199

# Supabase (ticket storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Internal contacts
ESCALATION_EMAIL=mgr@camelot.nyc

# Polling
EMAIL_POLL_INTERVAL=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/concierge_bot.log
